# Sakura AI — LLM Configuration
# Copy this file to .env and fill in your Gemini API key.
# Get a FREE key at: https://aistudio.google.com/apikey
# Without a key, Sakura AI runs in Database mode (still very useful!).

GEMINI_API_KEY=your-gemini-api-key-here

# Optional: change model (default is gemini-2.0-flash — fast and free)
# GEMINI_MODEL=gemini-2.0-flash
