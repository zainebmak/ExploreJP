# Sakura AI — LLM Configuration
# Copy this file to .env and fill in your key to enable full AI mode.
# Without a key, Sakura AI runs in Database mode (still very useful!).

OPENAI_API_KEY=sk-your-key-here

# Optional: change model (default is gpt-4o-mini — fast and cheap)
# OPENAI_MODEL=gpt-4o-mini
